# Local development
DATABASE_URL=postgres://studydock:studydock@localhost:5433/studydock
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Optional: require invite codes on register
# INVITE_ONLY=1

# Attachments (Cloudflare R2) — without these, small files use data URLs
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# Calendar sync
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=

# Stripe (optional monetization)
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=

# Production (Neon + Vercel) — set in Vercel dashboard
# DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# AUTH_SECRET=different-secret-use-openssl-rand-base64-32
# AUTH_URL=https://your-app.vercel.app
