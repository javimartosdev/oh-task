{
  "name": "oh-task",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:clean": "rm -rf .next && npm run dev:up",
    "db:up": "docker start oh-task-db 2>/dev/null || docker run -d --name oh-task-db -p 5434:5432 -e POSTGRES_USER=ohtask -e POSTGRES_PASSWORD=ohtask -e POSTGRES_DB=ohtask -v oh_task_pg:/var/lib/postgresql/data --restart unless-stopped postgres:16-alpine",
    "dev:up": "npm run db:up && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "icons:generate": "bash scripts/generate-icons.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^18.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
